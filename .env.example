# Firebase web config — copy to .env and fill from the Firebase console.
# These are NOT secrets: they identify the project and ship in the client
# bundle. Security comes from Firestore rules + Auth restrictions.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
