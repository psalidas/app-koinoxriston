rules_version = '2';

// Διαχείριση Πολυκατοικίας — multi-building, membership-based access.
//
// Residents/owners are external users; πρόσβαση δίνεται ανά χρήστη μέσω
// /users/{email} doc (ρόλος + buildingIds) και ανά κτίριο μέσω
// /buildings/{bid}/members/{userId}. Ένας bootstrap admin είναι hardcoded ώστε
// το πρώτο deploy να μπορεί να στήσει τα πρώτα docs.
//
// Απομόνωση δεδομένων (Phase 4):
//   - Τα δεδομένα κάθε συλλογής φέρουν `buildingId`. Διαβάζει/γράφει μόνο όποιος
//     ανήκει/διαχειρίζεται το συγκεκριμένο κτίριο· ο superadmin τα βλέπει όλα.
//   - Οι λίστες φιλτράρουν πάντα με `where('buildingId','==',X)`, οπότε ο κανόνας
//     canRead/canManage αποτιμάται με σταθερό bid ⇒ το query επιτρέπεται.
//   - Δίχτυ ασφαλείας: επιτρέπεται και μέσω users.buildingIds (πιο επιτρεπτικό,
//     ποτέ δεν κλειδώνει — δεν διαρρέει, τα buildingIds είναι ανά χρήστη).
//
// Roles: 'admin' | 'manager' | 'owner' | 'resident'
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    // Membership identifier. Οι magic-link συνεδρίες φέρουν custom claim
    // `identifier`· αλλιώς email, αλλιώς αριθμός τηλεφώνου. Ελέγχουμε την ύπαρξη
    // του claim με `in` ΠΡΙΝ την προσπελάσουμε (η προσπέλαση ανύπαρκτου claim σε
    // σύνδεση Google κάνει την αποτίμηση να αποτύχει → άρνηση).
    function uid() {
      return ('identifier' in request.auth.token && request.auth.token.identifier != null)
        ? request.auth.token.identifier
        : ('email' in request.auth.token && request.auth.token.email != null)
        ? request.auth.token.email
        : ('phone_number' in request.auth.token && request.auth.token.phone_number != null)
        ? request.auth.token.phone_number
        : null;
    }

    function isBootstrapAdmin() {
      return isAuthed() && request.auth.token.email == 'michael@crowdpolicy.com';
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(uid()));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function isKnownUser() {
      return isAuthed() && (isBootstrapAdmin() || userExists());
    }

    // «Global» διαχειριστής (ρόλος admin/manager στο /users) — για ενέργειες εκτός
    // κτιρίου (π.χ. δημιουργία νέου κτιρίου, διαχείριση χρηστών).
    function isManager() {
      return isAuthed() && (
        isBootstrapAdmin()
        || (userExists() && userDoc().role in ['admin', 'manager'])
      );
    }

    function isSuperadmin() {
      return isAuthed() && (
        isBootstrapAdmin()
        || (userExists() && userDoc().get('superadmin', false) == true)
      );
    }

    // Μέλος συγκεκριμένου κτιρίου.
    function memberExists(bid) {
      return exists(/databases/$(database)/documents/buildings/$(bid)/members/$(uid()));
    }
    function memberRole(bid) {
      return get(/databases/$(database)/documents/buildings/$(bid)/members/$(uid())).data.get('role', '');
    }

    // Δίχτυ ασφαλείας: το κτίριο περιλαμβάνεται στα buildingIds του χρήστη.
    function inMyBuildingIds(bid) {
      return userExists()
        && 'buildingIds' in userDoc()
        && bid in userDoc().buildingIds;
    }

    // Ανάγνωση δεδομένων κτιρίου: superadmin, ή μέλος, ή (δίχτυ) buildingIds.
    function canRead(bid) {
      return isAuthed() && (
        isSuperadmin()
        || memberExists(bid)
        || inMyBuildingIds(bid)
      );
    }

    // Διαχείριση δεδομένων κτιρίου: superadmin, ή μέλος-διαχειριστής, ή (δίχτυ)
    // global manager με το κτίριο στα buildingIds του.
    function canManage(bid) {
      return isAuthed() && (
        isSuperadmin()
        || (memberExists(bid) && memberRole(bid) in ['admin', 'manager'])
        || (inMyBuildingIds(bid) && isManager())
      );
    }

    // Default deny.
    match /{document=**} { allow read, write: if false; }

    // /users — ο χρήστης διαβάζει το δικό του doc· ο superadmin όλους· ο
    // διαχειριστής μόνο χρήστες που μοιράζονται κτίριο μαζί του (η λίστα κάνει
    // query με array-contains-any στα κτίρια του διαχειριστή).
    match /users/{userId} {
      allow read: if isSuperadmin()
        || (isAuthed() && uid() == userId)
        || (isManager()
            && resource.data.get('buildingIds', []).hasAny(userDoc().get('buildingIds', [])));
      allow create, update, delete: if isManager();
    }

    // Κατάλογος κτιρίων — όλοι οι γνωστοί χρήστες διαβάζουν (η εφαρμογή τα φιλτράρει
    // ανά χρήστη client-side)· δημιουργία από global manager· επεξεργασία μόνο από
    // διαχειριστή του συγκεκριμένου κτιρίου.
    match /buildings/{id} {
      allow read: if isKnownUser();
      allow create: if isManager();
      allow update, delete: if isSuperadmin() || canManage(id);
    }
    // Μέλη κτιρίου — γνωστοί χρήστες διαβάζουν· global manager γράφει (χρειάζεται
    // κατά τη δημιουργία κτιρίου, πριν υπάρξει member doc του δημιουργού).
    match /buildings/{bid}/members/{userId} {
      allow read: if isKnownUser();
      allow write: if isManager() || canManage(bid);
    }

    // ── Δεδομένα κτιρίου (buildingId-scoped) ──────────────────────────────────
    match /apartments/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /people/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /expenses/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    // Αύξοντες μετρητές ανά κτίριο (doc id == buildingId).
    match /counters/{id} {
      allow read, write: if canManage(id);
    }
    match /payments/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /statements/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /fundEntries/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /documents/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /announcements/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /contracts/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /works/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /contacts/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /assemblies/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }

    // Βλάβες — μέλη κτιρίου διαβάζουν & δημιουργούν· διαχειριστές του κτιρίου
    // ενημερώνουν/διαγράφουν.
    match /tickets/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canRead(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }

    // Συζήτηση — θέματα ανά κτίριο· σχόλια/προσφορές ανά θέμα (γνωστοί χρήστες).
    match /topics/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canRead(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /comments/{id} {
      allow read: if isKnownUser();
      allow create: if isKnownUser();
      allow update: if false;
      allow delete: if isManager();
    }
    match /offers/{id} {
      allow read: if isKnownUser();
      allow create: if isKnownUser();
      allow update: if false;
      allow delete: if isManager();
    }

    // Ψηφοφορίες ανά κτίριο· ψήφοι ανά ψηφοφορία (ο ψηφοφόρος γράφει τη δική του).
    match /polls/{id} {
      allow read: if canRead(resource.data.buildingId);
      allow create: if canManage(request.resource.data.buildingId);
      allow update, delete: if canManage(resource.data.buildingId);
    }
    match /votes/{id} {
      allow read: if isManager() || (isAuthed() && resource.data.voterId == uid());
      allow create, update: if isKnownUser()
        && request.resource.data.voterId == uid();
      allow delete: if isManager();
    }

    // Mail queue (firestore-send-email) — μόνο από trusted Cloud Functions.
    match /mail/{id} {
      allow read, write: if false;
    }

    // App settings (π.χ. settings/invites) — global manager. Τα API keys μένουν
    // στα functions env.
    match /settings/{id} {
      allow read, write: if isManager();
    }

    // Magic-link tokens — ΜΟΝΟ Admin SDK.
    match /magicTokens/{token} {
      allow read, write: if false;
    }

    // Ιδιωτικό προφίλ επικοινωνίας — ο χρήστης το επεξεργάζεται μόνος του·
    // ορατό στον ίδιο και στους διαχειριστές.
    match /profiles/{id} {
      allow read: if isManager() || (isAuthed() && uid() == id);
      allow write: if isManager() || (isAuthed() && uid() == id);
    }

    // Κατάλογος ιδιοκτητών/ενοίκων — μόνο ορατά πεδία. Γνωστοί χρήστες διαβάζουν·
    // ο καθένας γράφει μόνο τη δική του εγγραφή.
    match /directory/{id} {
      allow read: if isKnownUser();
      allow write: if isManager() || (isAuthed() && uid() == id);
    }

    // Audit log — διαχειριστής του κτιρίου διαβάζει (query φιλτράρει buildingId)·
    // κάθε γνωστός χρήστης καταγράφει μόνο δικές του ενέργειες.
    match /auditLogs/{id} {
      allow read: if isSuperadmin() || canManage(resource.data.buildingId);
      allow create: if isKnownUser() && request.resource.data.userEmail == uid();
      allow update, delete: if false;
    }
  }
}
