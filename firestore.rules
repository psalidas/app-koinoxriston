rules_version = '2';

// Διαχείριση Πολυκατοικίας — membership-based access.
//
// Unlike the domain-locked Crowdpolicy internal apps, residents/owners are
// external users, so access is granted per-user via a /users/{email} document
// created by a manager. A bootstrap admin is hardcoded so the very first
// deploy can create the first /users docs.
//
// Roles: 'admin' | 'manager' | 'owner' | 'resident'
//   - admin/manager  → full read/write on domain data
//   - owner/resident → read data for their building(s); write only their own
//                      participation (votes, tickets, topic comments) [Phase 2/3]
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    // Membership identifier. Οι magic-link συνεδρίες φέρουν custom claim
    // `identifier` (= το id του /users doc) ώστε να ταυτοποιούνται αξιόπιστα
    // email & κινητό. Αλλιώς email, αλλιώς αριθμός τηλεφώνου.
    function uid() {
      return request.auth.token.identifier != null
        ? request.auth.token.identifier
        : request.auth.token.email != null
        ? request.auth.token.email
        : request.auth.token.phone_number;
    }

    function isBootstrapAdmin() {
      return isAuthed() && request.auth.token.email == 'michael@crowdpolicy.com';
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function isKnownUser() {
      return isAuthed() && (
        isBootstrapAdmin()
        || exists(/databases/$(database)/documents/users/$(uid()))
      );
    }

    function isManager() {
      return isAuthed() && (
        isBootstrapAdmin()
        || (
          exists(/databases/$(database)/documents/users/$(uid()))
          && userDoc().role in ['admin', 'manager']
        )
      );
    }

    // Default deny.
    match /{document=**} { allow read, write: if false; }

    // /users — managers manage; a user can read their own doc.
    match /users/{userId} {
      allow read: if isManager() || (isAuthed() && uid() == userId);
      allow create, update, delete: if isManager();
    }

    // Building configuration & directory — known users read, managers write.
    match /buildings/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }
    match /apartments/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }
    match /people/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }

    // Financials — known users read, managers write.
    match /expenses/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }
    match /payments/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }
    match /statements/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }
    match /fundEntries/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }

    // Documents / announcements — known users read, managers write.
    match /documents/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }
    match /announcements/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }

    // Tickets (βλάβες) — known users read & create; managers update/delete.
    match /tickets/{id} {
      allow read: if isKnownUser();
      allow create: if isKnownUser();
      allow update, delete: if isManager();
    }

    // Contracts (συμβόλαια) — known users read, managers write.
    match /contracts/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }

    // Mail queue for the firestore-send-email extension — written only from
    // trusted Cloud Functions (admin SDK bypasses rules). Deny all clients.
    match /mail/{id} {
      allow read, write: if false;
    }

    // Discussion — known users read & participate; managers moderate.
    match /topics/{id} {
      allow read: if isKnownUser();
      allow create: if isKnownUser();
      allow update, delete: if isManager();
    }
    match /comments/{id} {
      allow read: if isKnownUser();
      allow create: if isKnownUser();
      allow update: if false;
      allow delete: if isManager();
    }
    match /offers/{id} {
      allow read: if isKnownUser();
      allow create: if isKnownUser();
      allow update: if false;
      allow delete: if isManager();
    }

    // Polls — managers manage; everyone known reads.
    match /polls/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }

    // Votes — a user writes only their own vote; managers (and the voter) read.
    match /votes/{id} {
      allow read: if isManager() || (isAuthed() && resource.data.voterId == uid());
      allow create, update: if isKnownUser()
        && request.resource.data.voterId == uid();
      allow delete: if isManager();
    }

    // Assemblies (ΓΣ) — known users read, managers write.
    match /assemblies/{id} {
      allow read: if isKnownUser();
      allow write: if isManager();
    }

    // App settings (π.χ. settings/invites) — managers only. Τα API keys ΔΕΝ
    // ζουν εδώ (μένουν στα functions env). Οι Cloud Functions διαβάζουν με
    // Admin SDK (bypass rules).
    match /settings/{id} {
      allow read, write: if isManager();
    }

    // Magic-link tokens — ΜΟΝΟ Admin SDK (functions). Καμία client πρόσβαση.
    match /magicTokens/{token} {
      allow read, write: if false;
    }

    // Audit log — managers read; writes happen from trusted context only.
    match /auditLogs/{id} {
      allow read: if isManager();
      allow create: if isManager();
      allow update, delete: if false;
    }
  }
}
