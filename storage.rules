rules_version = '2';

// Storage for expense receipts, documents, and offers.
// Read: any authenticated user. Write: authenticated users (managers in
// practice, enforced at the app layer + Firestore metadata). Tighten with
// custom claims when the resident portal ships.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('application/pdf')
        );
    }
  }
}
